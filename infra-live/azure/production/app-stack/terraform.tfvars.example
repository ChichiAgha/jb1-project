subscription_id = "00000000-0000-0000-0000-000000000000"

resource_group = {
  create      = true
  location    = "UK South"
  name_prefix = "taskapp-prod"
}

network = {
  name_prefix   = "taskapp-prod"
  address_space = ["10.30.0.0/16"]
  public_subnets = {
    public-a = {
      address_prefixes = ["10.30.1.0/24"]
    }
  }
  private_subnets = {
    private-a = {
      address_prefixes = ["10.30.11.0/24"]
    }
  }
  nat_gateway_subnet_keys = ["private-a"]
}

security = {
  alb_ingress_cidrs = ["0.0.0.0/0"]
  app_port          = 80
}

load_balancer = {
  sku_name          = "Standard_v2"
  sku_tier          = "Standard_v2"
  capacity          = 2
  frontend_port     = 80
  backend_port      = 80
  health_check_path = "/api/health"
}

compute = {
  vm_sku             = "Standard_B2s"
  instances          = 2
  admin_username     = "azureuser"
  ssh_public_key     = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQDreplace-me"
  dockerhub_username = "your-dockerhub-username"
  image_tag          = "latest"
  zones              = ["1", "2"]
  image_reference = {
    publisher = "Canonical"
    offer     = "0001-com-ubuntu-server-jammy"
    sku       = "22_04-lts"
    version   = "latest"
  }
  backend_env = {
    app_env     = "production"
    app_debug   = "false"
    db_host     = "your-postgres-host"
    db_port     = "5432"
    db_database = "taskapp"
    db_username = "taskuser"
    db_password = "change-me"
  }
}

tags = {
  Project     = "jb1-project"
  Environment = "production"
  Owner       = "platform"
}
